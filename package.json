{
  "name": "code-pirate",
  "displayName": "Code Pirate",
  "description": "A 1:1 GitHub Copilot replacement built for developers who are done being held hostage and gaslit by SaaS bait-and-switches.",
  "version": "0.1.19",
  "publisher": "codepirate",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/anjeleno/codepirate-public"
  },
  "bugs": {
    "url": "https://github.com/anjeleno/codepirate-public/issues"
  },
  "homepage": "https://codepirate.cc",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "ai",
    "copilot",
    "llm",
    "anthropic",
    "openai",
    "ollama",
    "byok"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "code-pirate-sidebar",
          "title": "Code Pirate",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "code-pirate-sidebar": [
        {
          "id": "codePirate.sidebar",
          "name": "Code Pirate",
          "type": "webview",
          "icon": "media/icon.svg",
          "contextualTitle": "Code Pirate"
        }
      ]
    },
    "commands": [
      {
        "command": "codePirate.inlineChat",
        "title": "Code Pirate: Inline Chat"
      },
      {
        "command": "codePirate.generateCommitMessage",
        "title": "Code Pirate: Generate Commit Message"
      },
      {
        "command": "codePirate.explainTerminalError",
        "title": "Code Pirate: Explain Terminal Error"
      },
      {
        "command": "codePirate.generateProjectRules",
        "title": "Code Pirate: Generate .projectrules"
      },
      {
        "command": "codePirate.activateLicense",
        "title": "Code Pirate: Activate License"
      },
      {
        "command": "codePirate.openSidebar",
        "title": "Code Pirate: Open Sidebar"
      },
      {
        "command": "codePirate.setupApiKey",
        "title": "Code Pirate: Set Up API Key"
      },
      {
        "command": "codePirate.runDiagnostics",
        "title": "Code Pirate: Run Diagnostics"
      },
      {
        "command": "codePirate.acceptInlineEdit",
        "title": "Code Pirate: Accept Inline Edit"
      },
      {
        "command": "codePirate.discardInlineEdit",
        "title": "Code Pirate: Discard Inline Edit"
      }
    ],
    "keybindings": [
      {
        "command": "codePirate.inlineChat",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "editorTextFocus"
      },
      {
        "command": "codePirate.acceptInlineEdit",
        "key": "tab",
        "when": "codePirate.pendingInlineEdit && editorTextFocus"
      },
      {
        "command": "codePirate.discardInlineEdit",
        "key": "escape",
        "when": "codePirate.pendingInlineEdit && editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Code Pirate",
      "properties": {
        "codePirate.provider": {
          "type": "string",
          "enum": [
            "openrouter",
            "anthropic-direct",
            "ollama",
            "lmstudio",
            "groq",
            "together",
            "mistral",
            "gemini",
            "custom"
          ],
          "enumDescriptions": [
            "OpenRouter — access all models with one key",
            "Anthropic Direct — direct to api.anthropic.com",
            "Ollama (Local) — localhost:11434",
            "LM Studio (Local) — localhost:1234",
            "Groq — fast inference",
            "Together AI",
            "Mistral",
            "Google Gemini (OpenAI compat)",
            "Custom — specify your own endpoint URL"
          ],
          "default": "openrouter",
          "description": "AI provider. Endpoint is auto-resolved. Use 'Custom' to override."
        },
        "codePirate.model": {
          "type": "string",
          "default": "deepseek/deepseek-v4-pro",
          "description": "Model identifier. Format depends on provider (e.g. 'deepseek/deepseek-v4-pro' for OpenRouter, 'claude-opus-4-5' for Anthropic Direct)."
        },
        "codePirate.apiEndpoint": {
          "type": "string",
          "default": "",
          "description": "Auto-resolved from provider. Set provider to 'Custom' to override with your own URL."
        },
        "codePirate.fallbackChain": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "openrouter",
            "anthropic-direct",
            "ollama"
          ],
          "description": "Provider fallback order on request failure."
        },
        "codePirate.enableInlineCompletions": {
          "type": "boolean",
          "default": false,
          "description": "Enable AI ghost-text completions as you type. Off by default — each keystroke fires a real API request against your key. Enable only if you understand and accept the per-token cost."
        }
      }
    }
  },
  "scripts": {
    "build:ext": "vite build --config vite.config.ts",
    "build:webview": "vite build --config webview/vite.config.ts",
    "build": "npm run build:ext && npm run build:webview",
    "watch:ext": "vite build --config vite.config.ts --watch",
    "watch:webview": "vite build --config webview/vite.config.ts --watch",
    "package": "npm run build && vsce package",
    "typecheck": "tsc --noEmit && tsc --noEmit --project webview/tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vscode/vsce": "^2.32.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
